<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:viewsTopbars="clr-namespace:ModpackInstaller.Views.Topbars"
			 xmlns:viewsSidebars="clr-namespace:ModpackInstaller.Views.Sidebars"
			 xmlns:viewsBody="clr-namespace:ModpackInstaller.Views.Body"
			 xmlns:vmTopbars="clr-namespace:ModpackInstaller.ViewModels.Topbars"
			 xmlns:vmSidebars="clr-namespace:ModpackInstaller.ViewModels.Sidebars"
			 xmlns:vmBody="clr-namespace:ModpackInstaller.ViewModels.Body"
			 xmlns:converters="clr-namespace:ModpackInstaller.Converters"
			 x:Class="ModpackInstaller.App"
			 RequestedThemeVariant="Dark">

	<Application.Styles>
		<!-- Tema Fluent -->
		<FluentTheme/>

		<!-- Stiluri generale pentru butoane -->
		<Style Selector="Button.nav">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Padding" Value="12"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
		</Style>

		<Style Selector="Button.nav:pointerover">
			<Setter Property="Background" Value="#2A2A2A"/>
		</Style>

		<Style Selector="Button.primary">
			<Setter Property="Background" Value="#4F8CFF"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="10,6"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>

		<Style Selector="Button.primary:pointerover">
			<Setter Property="Background" Value="#6AA1FF"/>
		</Style>

		<Style Selector="Button.ghost">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#AAAAAA"/>
		</Style>

		<!-- ScrollViewer modern -->
		<Style Selector="ScrollViewer">
			<Setter Property="Background" Value="#1E1E1E"/>
		</Style>

		<Style Selector="Button.topbar">
			<Setter Property="Background" Value="#4F8CFF"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Padding" Value="10,6"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
		</Style>

		<Style Selector="Button.topbar:pointerover">
			<Setter Property="Background" Value="#3A70D1"/>
		</Style>
	</Application.Styles>

	<Application.DataTemplates>
		<DataTemplate DataType="vmTopbars:GlobalTopBarViewModel">
			<viewsTopbars:GlobalTopBarView />
		</DataTemplate>
		<DataTemplate DataType="vmTopbars:ModpackTopBarViewModel">
			<viewsTopbars:ModpackTopBarView />
		</DataTemplate>
		<DataTemplate DataType="vmSidebars:ModpackListViewModel">
			<viewsSidebars:ModpackListView />
		</DataTemplate>
		<DataTemplate DataType="vmSidebars:ModListViewModel">
			<viewsSidebars:ModListView />
		</DataTemplate>
		<DataTemplate DataType="vmBody:ModpackInfoViewModel">
			<viewsBody:ModpackInfoView />
		</DataTemplate>
		<DataTemplate DataType="vmBody:ModpackDiscoveryViewModel">
			<viewsBody:ModpackDiscoveryView />
		</DataTemplate>
		<DataTemplate DataType="vmBody:ModrinthBrowserViewModel">
			<viewsBody:ModrinthBrowserView />
		</DataTemplate>
	</Application.DataTemplates>

	<Application.Resources>
		<converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
		<converters:NegateBoolConverter x:Key="NegateBool"/>
	</Application.Resources>
</Application>
