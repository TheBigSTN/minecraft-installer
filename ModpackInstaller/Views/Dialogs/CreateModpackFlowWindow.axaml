<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:ModpackInstaller.Views"
    xmlns:vm="clr-namespace:ModpackInstaller.ViewModels.Dialogs"
	x:DataType="vm:CreateModpackFlowViewModel"
    x:Class="ModpackInstaller.Windows.CreateModpackFlowWindow"
	xmlns:model="ModpackInstaller.Models"
    Width="500"
    Height="400"
    Title="Create Modpack">

	<StackPanel>

		<!-- CONTENT -->
		<ContentControl Content="{Binding CurrentStep}">
			<ContentControl.DataTemplates>
				<DataTemplate DataType="vm:SelectPlatformStepViewModel">
					<views:Step1PlatformView/>
				</DataTemplate>
				<DataTemplate DataType="vm:ConfigureStepViewModel">
					<views:Step2ConfigView/>
				</DataTemplate>
				<DataTemplate DataType="vm:ConfirmStepViewModel">
					<views:Step3ConfirmView/>
				</DataTemplate>
			</ContentControl.DataTemplates>
		</ContentControl>

		<!-- NAV -->
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

			<Button Content="Back" Command="{Binding Back}" />
			<Button Content="Next" Command="{Binding Next}" />
			<Button Content="Finish" Command="{Binding Finish}" />

		</StackPanel>

	</StackPanel>

</Window>