	<UserControl xmlns="https://github.com/avaloniaui"
				 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				 xmlns:vm="clr-namespace:ModpackInstaller.ViewModels"
				 x:Class="ModpackInstaller.Views.MainView"
				 x:DataType="vm:MainViewModel"
				 Focusable="True">

		<Grid ColumnDefinitions="220,*"
				  RowDefinitions="56,*"
				  Background="#121212">

				<ContentControl
					Grid.Row="0"
					Grid.Column="0"
					Grid.ColumnSpan="2"
					ZIndex="1"
					Content="{Binding TopBarViewModel}"/>

				<ContentControl
					Grid.Row="1"
					Grid.Column="0"
					VerticalAlignment="Stretch"
					HorizontalAlignment="Stretch"
					Content="{Binding SidebarViewModel}"/>

				<ContentControl
					Grid.Row="1"
					Grid.Column="1"
					VerticalAlignment="Stretch"
					HorizontalAlignment="Stretch"
					Content="{Binding BodyViewModel}"/>
			</Grid>
	</UserControl>
