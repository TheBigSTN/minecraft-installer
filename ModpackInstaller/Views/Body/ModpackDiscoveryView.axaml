<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ModpackInstaller.Models.DTOs"
             xmlns:vm="clr-namespace:ModpackInstaller.ViewModels.Body"
             x:Class="ModpackInstaller.Views.Body.ModpackDiscoveryView"
             x:DataType="vm:ModpackDiscoveryViewModel">

	<Grid RowDefinitions="Auto, *">
		<StackPanel Orientation="Horizontal" Margin="10" Spacing="10">
			<TextBlock Text="Community Modpacks" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
			<Button Content="Refresh" Command="{Binding RefreshCommand}" />
		</StackPanel>

		<ListBox Grid.Row="1" ItemsSource="{Binding DiscoveryModpacks}">
			<ListBox.ItemTemplate>
				<DataTemplate x:DataType="models:PublicModpackRequestResponse">
					<Grid Margin="10">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<StackPanel Spacing="5">
							<StackPanel Orientation="Horizontal" Spacing="10">
								<TextBlock Text="{Binding ModpackName}" FontSize="16" FontWeight="Bold" Foreground="LightBlue"/>
								<Border Background="#444" CornerRadius="4" Padding="4,2">
									<TextBlock Text="{Binding GameVersion}" FontSize="10"/>
								</Border>
							</StackPanel>

							<TextBlock Text="{Binding Description}"
                                       FontSize="12"
                                       Foreground="#AAA"
                                       TextWrapping="Wrap"
                                       MaxLines="2"/>

							<StackPanel Orientation="Horizontal" Spacing="15">
								<TextBlock Text="{Binding AuthorName, StringFormat='By: {0}'}" FontSize="11" Foreground="#888"/>
								<TextBlock Text="{Binding Loader, StringFormat='Type: {0}'}" FontSize="11" Foreground="#888"/>
							</StackPanel>
						</StackPanel>

						<Button Grid.Column="1"
							Content="Download"
							VerticalAlignment="Center"
							x:CompileBindings="False"
							Command="{Binding $parent[ListBox].((vm:ModpackDiscoveryViewModel)DataContext).InstallModpackCommand}"
							CommandParameter="{Binding}" />
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</UserControl>