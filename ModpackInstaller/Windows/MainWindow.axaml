<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ModpackInstaller.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ModpackInstaller.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="ModpackInstaller.Views.MainWindow"
        Icon="/Assets/image-1.ico"
        Title="Modpack Installer"
        Height="600"
        Width="900"
        Background="#FF1E1E1E"
        TransparencyLevelHint="AcrylicBlur"
        CanResize="True">

	<!-- Folosim un Border cu colțuri rotunjite și shadow pentru efect modern -->
	<Border CornerRadius="12"
            Background="#FF1E1E1E"
            Padding="0"
            Margin="0">
		<views:MainView />
	</Border>
</Window>